# Frontend-visible values. Vite exposes only variables prefixed with VITE_ to client code.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional frontend feature flag. Keep false until a backend/proxy route exists.
VITE_AI_BACKEND_ENABLED=false

# Backend-only secrets. Never import or read these from frontend/client code.
SUPABASE_SERVICE_ROLE_KEY=
AI_PROVIDER_API_KEY=
AI_PROVIDER=
